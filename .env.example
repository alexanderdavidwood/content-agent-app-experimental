OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
MASTRA_USE_CLOUD_STORAGE=
MASTRA_STORAGE_URL=
MASTRA_STORAGE_AUTH_TOKEN=
# Exact frontend origin allowed to call the Mastra backend with credentials.
# For hosted Contentful app bundles this is usually the iframe origin, such as
# https://<app-host>.ctfcloud.net, not https://app.contentful.com.
ALLOWED_ORIGIN=
ALLOWED_ORIGIN_EU=
# Optional generic production mode for Contentful-hosted app bundles.
# When true, the backend reflects trusted Contentful app origins like
# https://<id>.ctfcloud.net instead of requiring one exact origin per bundle.
ALLOW_CONTENTFUL_HOSTED_APP_ORIGINS=
VITE_PORT=3000
VITE_DEV_SSL_KEY_PATH=
VITE_DEV_SSL_CERT_PATH=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_ORG_ID=
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT_ID=master
